# ─── TapMenu Armenia Environment Variables ─────────────────────────────────

# Database (PostgreSQL / Supabase)
# For local development with SQLite, comment out and use: DATABASE_URL="file:./dev.db"
# For production, use Supabase or any PostgreSQL provider:
DATABASE_URL="postgresql://user:password@host:5432/tapmenu"

# Supabase (optional, for auth and storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# App URL
NEXT_PUBLIC_APP_URL="https://app.tapmenu.am"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# OpenAI (for AI assistant)
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# Security
JWT_SECRET="your-secret-key-min-32-chars"
ENCRYPTION_KEY="your-aes-256-key"
