import { NextRequest, NextResponse } from 'next/server'
import { prisma } from '@/lib/prisma'

// POST /api/cron/update-rates - Called by Vercel Cron at 09:00 AM
// Schedule: 0 9 * * * (daily at 09:00)
export async function POST(request: NextRequest) {
  // Verify cron secret
  const authHeader = request.headers.get('authorization')
  if (authHeader !== `Bearer ${process.env.CRON_SECRET}`) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
  }

  try {
    const today = new Date().toISOString().split('T')[0]
    const response = await fetch(
      `https://api.cba.am/exchangerates.asmx/ExchangeRatesByDate?DateExchangeRate=${today}`
    )

    if (!response.ok) throw new Error('CBA API unavailable')

    const xml = await response.text()

    const extractRate = (code: string): number | null => {
      const match = xml.match(
        new RegExp(`<ISO_4217>${code}<\\/ISO_4217>.*?<Rate>([\\d.]+)<\\/Rate>`, 's')
      )
      return match ? parseFloat(match[1]) : null
    }

    const ratesToUpdate = [
      { from: 'USD', rate: extractRate('USD') },
      { from: 'EUR', rate: extractRate('EUR') },
      { from: 'RUB', rate: extractRate('RUB') },
      { from: 'GBP', rate: extractRate('GBP') },
    ].filter((r) => r.rate !== null)

    await Promise.all(
      ratesToUpdate.map((r) =>
        prisma.exchangeRate.upsert({
          where: { fromCurrency_toCurrency: { fromCurrency: r.from!, toCurrency: 'AMD' } },
          update: { rate: r.rate!, updatedAt: new Date() },
          create: { fromCurrency: r.from!, toCurrency: 'AMD', rate: r.rate! },
        })
      )
    )

    // Block accounts in grace period that have expired
    await prisma.subscription.updateMany({
      where: {
        status: 'grace',
        graceEndsAt: { lt: new Date() },
      },
      data: { status: 'blocked' },
    })

    return NextResponse.json({
      success: true,
      updated: ratesToUpdate.length,
      timestamp: new Date().toISOString(),
    })
  } catch (error) {
    console.error('Cron job error:', error)
    return NextResponse.json({ error: 'Cron job failed' }, { status: 500 })
  }
}

// Allow GET for Vercel Cron
export async function GET(request: NextRequest) {
  return POST(request)
}
